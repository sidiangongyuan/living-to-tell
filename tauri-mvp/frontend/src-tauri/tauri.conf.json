{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "活着为了讲述",
  "version": "0.1.25",
  "identifier": "com.livingtotell.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "活着为了讲述",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "backgroundColor": "#f8fafc"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/living-to-tell-backend"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["English", "SimpChinese"],
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    }
  }
}
